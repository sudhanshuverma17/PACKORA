 
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Forgot Password | PACKORA</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-100 min-h-screen flex items-center justify-center px-4">

<div class="w-full max-w-md bg-white rounded-3xl shadow-xl p-8">

    <div class="text-center mb-8">
        <h1 class="text-4xl font-bold tracking-wide">PACKORA</h1>
        <p class="text-gray-500 text-sm mt-1">Premium Carry Essentials</p>
    </div>

    <div class="mb-6 text-center">
        <h2 class="text-2xl font-semibold">Forgot Password</h2>
        <p class="text-gray-500 text-sm mt-2">
            Enter your registered email and receive a reset link.
        </p>
    </div>

    <% if(error && error.length > 0){ %>
        <div class="bg-red-100 text-red-600 px-4 py-3 rounded-lg mb-4 text-sm">
            <%= error %>
        </div>
    <% } %>

    <% if(success && success.length > 0){ %>
        <div class="bg-green-100 text-green-600 px-4 py-3 rounded-lg mb-4 text-sm">
            <%= success %>
        </div>
    <% } %>

    <form action="/users/forgot-password" method="POST" class="space-y-4">

        <input
            type="email"
            name="email"
            placeholder="Enter your email"
            required
            class="w-full border border-zinc-300 rounded-xl px-4 py-3 outline-none focus:ring-2 focus:ring-black"
        >

        <button
            class="w-full bg-black text-white py-3 rounded-xl hover:bg-zinc-800 transition"
        >
            Send Reset Link
        </button>

    </form>

    <p class="text-center text-sm text-gray-500 mt-6">
        Remember password?
        <a href="/" class="text-black font-semibold hover:underline">
            Login
        </a>
    </p>

</div>

</body>
</html>

