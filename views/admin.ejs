
<%- include('./partials/header') %>

<div class="w-full min-h-screen px-4 md:px-8 lg:px-16 py-8">

    <h2 class="text-3xl font-bold mb-8">Admin Dashboard</h2>

    <div class="flex flex-col xl:flex-row gap-8">

        <!-- LEFT : FORM -->
        <div class="w-full xl:w-1/3">

            <div class="bg-white rounded-2xl shadow p-6">

                <h3 class="text-2xl font-semibold mb-6">Add Product</h3>

                <form action="/products/create"
                      method="POST"
                      enctype="multipart/form-data"
                      class="space-y-4">

                    <input
                        name="image"
                        type="file"
                        class="w-full border rounded-lg p-3"
                        required
                    >

                    <input
                        name="name"
                        type="text"
                        placeholder="Product Name"
                        class="w-full border rounded-lg p-3"
                        required
                    >

                    <input
                        name="price"
                        type="number"
                        placeholder="Price"
                        class="w-full border rounded-lg p-3"
                        required
                    >

                    <input
                        name="discount"
                        type="number"
                        placeholder="Discount"
                        class="w-full border rounded-lg p-3"
                    >

                    <!-- COLORS -->
                    <div>
                        <label class="text-sm font-medium block mb-1">
                            Background Color
                        </label>

                        <input
                            name="bgcolor"
                            type="color"
                            class="w-full h-12 rounded-lg border"
                        >
                    </div>

                    <div>
                        <label class="text-sm font-medium block mb-1">
                            Panel Color
                        </label>

                        <input
                            name="panelcolor"
                            type="color"
                            class="w-full h-12 rounded-lg border"
                        >
                    </div>

                    <div>
                        <label class="text-sm font-medium block mb-1">
                            Text Color
                        </label>

                        <input
                            name="textcolor"
                            type="color"
                            class="w-full h-12 rounded-lg border"
                        >
                    </div>

                    <button
                        class="w-full bg-blue-500 hover:bg-blue-600 text-white py-3 rounded-xl transition">
                        Create Product
                    </button>

                </form>

            </div>

        </div>

        <!-- RIGHT : PRODUCTS -->
        <div class="w-full xl:w-2/3">

            <div class="bg-white rounded-2xl shadow p-6">

                <div class="flex justify-between items-center mb-6">
                    <h3 class="text-2xl font-semibold">All Products</h3>

                    <span class="text-sm text-gray-500">
                        <%= products ? products.length : 0 %> Products
                    </span>
                </div>

                <% if(products && products.length > 0){ %>

                    <div class="space-y-4">

                    <% products.forEach(product => { %>

                    <div class="border rounded-2xl p-4 flex flex-col md:flex-row md:items-center md:justify-between gap-4 hover:shadow-md transition">

                        <!-- LEFT -->
                        <div class="flex items-center gap-4">

                            <% if(product.image){ %>

                            <img
                                src="data:image/png;base64,<%= product.image.toString('base64') %>"
                                class="w-20 h-20 object-cover rounded-xl border"
                            />

                            <% } %>

                            <div>

                                <h4 class="font-semibold text-lg">
                                    <%= product.name %>
                                </h4>

                                <p class="text-sm text-gray-600 mt-1">
                                    ₹ <%= product.price %>
                                    <% if(product.discount > 0){ %>
                                        (- <%= product.discount %>)
                                    <% } %>
                                </p>

                            </div>

                        </div>

                        <!-- ACTIONS -->
                        <div class="flex gap-3">

                            <a href="/products/edit/<%= product._id %>"
                               class="bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg transition">
                               Edit
                            </a>

                            <form action="/products/delete/<%= product._id %>" method="POST">

                                <button
                                    type="submit"
                                    class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg transition">
                                    Delete
                                </button>

                            </form>

                        </div>

                    </div>

                    <% }) %>

                    </div>

                <% } else { %>

                    <div class="text-center py-10 text-gray-500">
                        No products available
                    </div>

                <% } %>

            </div>

        </div>

    </div>

</div>

<%- include('./partials/footer') %>

