 
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reset Password | PACKORA</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-zinc-100 min-h-screen flex items-center justify-center px-4">

<div class="w-full max-w-md bg-white rounded-3xl shadow-xl p-8">

    <!-- BRAND -->
    <div class="text-center mb-8">
        <h1 class="text-4xl font-bold tracking-wide">PACKORA</h1>
        <p class="text-gray-500 text-sm mt-1">Premium Carry Essentials</p>
    </div>

    <!-- TITLE -->
    <div class="mb-6 text-center">
        <h2 class="text-2xl font-semibold">Reset Password</h2>
        <p class="text-gray-500 text-sm mt-2">
            Create a new secure password for your account.
        </p>
    </div>

    <!-- FORM -->
    <form action="/users/reset-password/<%= token %>" method="POST" class="space-y-4">

        <div class="relative">

            <input
                type="password"
                name="password"
                id="password"
                placeholder="New Password"
                required
                class="w-full border border-zinc-300 rounded-xl px-4 py-3 pr-12 outline-none focus:ring-2 focus:ring-black"
            >

            <button
                type="button"
                onclick="togglePassword()"
                class="absolute right-4 top-1/2 -translate-y-1/2 text-gray-500"
            >
                👁
            </button>

        </div>

        <button
            class="w-full bg-black text-white py-3 rounded-xl hover:bg-zinc-800 transition"
        >
            Reset Password
        </button>

    </form>

    <p class="text-center text-sm text-gray-500 mt-6">
        <a href="/" class="text-black font-semibold hover:underline">
            Back to Login
        </a>
    </p>

</div>

<script>
function togglePassword() {
    const input = document.getElementById("password");

    if (input.type === "password") {
        input.type = "text";
    } else {
        input.type = "password";
    }
}
</script>

</body>
</html>
 
