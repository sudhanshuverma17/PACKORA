<%- include('./partials/header') %>

<div class="w-full min-h-screen flex items-center justify-center px-4 py-10">

    <div class="w-full max-w-md bg-white shadow-2xl rounded-2xl p-8">

        <h2 class="text-3xl font-bold text-center mb-2">
            Join <span class="text-blue-500">PACKORA</span>
        </h2>

        <p class="text-gray-500 text-center mb-6">
            Create your account
        </p>

        <form action="/users/register" method="POST" class="space-y-4">

            <input
                type="text"
                name="fullname"
                placeholder="Full Name"
                class="w-full bg-zinc-100 px-4 py-3 rounded-lg border"
                required
            >

            <input
                type="email"
                name="email"
                placeholder="Email"
                class="w-full bg-zinc-100 px-4 py-3 rounded-lg border"
                required
            >

            <input
                type="password"
                name="password"
                placeholder="Password"
                class="w-full bg-zinc-100 px-4 py-3 rounded-lg border"
                required
            >

            <button class="w-full bg-green-500 hover:bg-green-600 text-white py-3 rounded-lg">
                Create Account
            </button>

        </form>

        <p class="text-center mt-6 text-sm">
            Already have an account?
            <a href="/" class="text-blue-500 font-semibold hover:underline">
                Login
            </a>
        </p>

    </div>

</div>

<%- include('./partials/footer') %>
