
<%- include('./partials/header') %>

<div class="w-full min-h-screen px-4 md:px-8 lg:px-16 py-8">

    <h2 class="text-3xl font-bold mb-8">Your Cart</h2>

    <% if(user.cart.length === 0){ %>

        <div class="bg-white rounded-2xl shadow p-10 text-center">
            <h3 class="text-xl font-semibold mb-2">Your cart is empty</h3>
            <p class="text-gray-500 mb-6">Looks like you haven’t added anything yet.</p>

            <a href="/shop"
               class="inline-block bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-lg transition">
               Continue Shopping
            </a>
        </div>

    <% } %>

    <% let total = 0; %>

    <div class="flex flex-col lg:flex-row gap-8">

        <!-- PRODUCTS -->
        <div class="w-full lg:w-2/3">

            <% user.cart.forEach(function(item){ 
                let product = item.product;
                let itemTotal = (product.price - product.discount) * item.quantity;
                total += itemTotal;
            %>

            <div class="bg-white rounded-2xl shadow p-4 md:p-5 mb-5">

                <div class="flex flex-col md:flex-row gap-5">

                    <!-- IMAGE -->
                    <div
                        class="w-full md:w-44 h-44 rounded-xl flex items-center justify-center"
                        style="background-color:<%= product.bgcolor %>">

                        <img
                            class="h-28 md:h-32 object-contain"
                            src="data:image/jpeg;base64,<%= product.image.toString('base64') %>">

                    </div>

                    <!-- DETAILS -->
                    <div class="flex-1 flex flex-col justify-between">

                        <div class="flex flex-col sm:flex-row sm:justify-between gap-3">

                            <div>
                                <h3 class="text-xl font-semibold">
                                    <%= product.name %>
                                </h3>

                                <p class="text-gray-600 mt-1">
                                    ₹ <%= product.price %>
                                </p>
                            </div>

                            <a href="/remove/<%= product._id %>"
                               class="text-red-500 hover:text-red-600 font-medium">
                               Remove
                            </a>

                        </div>

                        <!-- QUANTITY -->
                        <div class="flex items-center gap-4 mt-5">

                            <a href="/update/<%= product._id %>/decrease"
                               class="px-3 py-1 bg-zinc-200 rounded hover:bg-zinc-300">
                               -
                            </a>

                            <span class="font-semibold">
                                <%= item.quantity %>
                            </span>

                            <a href="/update/<%= product._id %>/increase"
                               class="px-3 py-1 bg-zinc-200 rounded hover:bg-zinc-300">
                               +
                            </a>

                        </div>

                        <!-- SUBTOTAL -->
                        <p class="mt-4 font-medium">
                            Subtotal: ₹ <%= itemTotal <= 0 ? 1 : itemTotal %>
                        </p>

                    </div>

                </div>

            </div>

            <% }) %>

        </div>

        <!-- SUMMARY -->
        <% if(user.cart.length > 0){ %>

        <div class="w-full lg:w-1/3">

            <div class="bg-white rounded-2xl shadow p-6 lg:sticky lg:top-24">

                <h3 class="text-2xl font-bold mb-5">Order Summary</h3>

                <div class="flex justify-between mb-3">
                    <span>Total Items</span>
                    <span><%= user.cart.length %></span>
                </div>

                <div class="flex justify-between text-lg font-semibold border-t pt-4">
                    <span>Total</span>
                    <span>₹ <%= total %></span>
                </div>

                <a href="/checkout"
                   class="block text-center mt-6 bg-green-500 hover:bg-green-600 text-white py-3 rounded-xl transition">
                   Proceed to Checkout
                </a>

                <a href="/shop"
                   class="block text-center mt-3 bg-zinc-100 hover:bg-zinc-200 py-3 rounded-xl transition">
                   Continue Shopping
                </a>

            </div>

        </div>

        <% } %>

    </div>

</div>

<%- include('./partials/footer') %>

